{
  "openapi": "3.1.0",
  "info": {
    "title": "Hanachan Domain Service",
    "description": "Single Source of Truth for Hanachan Business Logic",
    "version": "0.1.0"
  },
  "paths": {
    "/api/v1/reading/submit-answer": {
      "post": {
        "tags": [
          "reading"
        ],
        "summary": "Submit Reading Answer",
        "description": "THIN ROUTER:\n- Validates request body (via Pydantic)\n- Extracts user_id from JWT\n- Delegates core logic to Domain Service",
        "operationId": "submit_reading_answer_api_v1_reading_submit_answer_post",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/AnswerSubmission"
              }
            }
          },
          "required": true
        },
        "responses": {
          "200": {
            "description": "Successful Response",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/AnswerResult"
                }
              }
            }
          },
          "422": {
            "description": "Validation Error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HTTPValidationError"
                }
              }
            }
          }
        },
        "security": [
          {
            "HTTPBearer": []
          }
        ]
      }
    },
    "/api/v1/learning/progress": {
      "get": {
        "tags": [
          "learning"
        ],
        "summary": "Get Progress",
        "operationId": "get_progress_api_v1_learning_progress_get",
        "security": [
          {
            "HTTPBearer": []
          }
        ],
        "parameters": [
          {
            "name": "identifier",
            "in": "query",
            "required": true,
            "schema": {
              "type": "string",
              "title": "Identifier"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Successful Response",
            "content": {
              "application/json": {
                "schema": {
                  "anyOf": [
                    {
                      "$ref": "#/components/schemas/KUStatus"
                    },
                    {
                      "type": "null"
                    }
                  ],
                  "title": "Response Get Progress Api V1 Learning Progress Get"
                }
              }
            }
          },
          "422": {
            "description": "Validation Error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HTTPValidationError"
                }
              }
            }
          }
        }
      }
    },
    "/api/v1/learning/search": {
      "get": {
        "tags": [
          "learning"
        ],
        "summary": "Search Ku",
        "operationId": "search_ku_api_v1_learning_search_get",
        "parameters": [
          {
            "name": "q",
            "in": "query",
            "required": true,
            "schema": {
              "type": "string",
              "title": "Q"
            }
          },
          {
            "name": "limit",
            "in": "query",
            "required": false,
            "schema": {
              "type": "integer",
              "default": 10,
              "title": "Limit"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Successful Response",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/KnowledgeUnit"
                  },
                  "title": "Response Search Ku Api V1 Learning Search Get"
                }
              }
            }
          },
          "422": {
            "description": "Validation Error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HTTPValidationError"
                }
              }
            }
          }
        }
      }
    },
    "/api/v1/learning/review": {
      "post": {
        "tags": [
          "learning"
        ],
        "summary": "Submit Review",
        "operationId": "submit_review_api_v1_learning_review_post",
        "security": [
          {
            "HTTPBearer": []
          }
        ],
        "parameters": [
          {
            "name": "ku_id",
            "in": "query",
            "required": true,
            "schema": {
              "type": "string",
              "title": "Ku Id"
            }
          },
          {
            "name": "facet",
            "in": "query",
            "required": true,
            "schema": {
              "type": "string",
              "title": "Facet"
            }
          },
          {
            "name": "rating",
            "in": "query",
            "required": true,
            "schema": {
              "$ref": "#/components/schemas/Rating"
            }
          },
          {
            "name": "wrong_count",
            "in": "query",
            "required": false,
            "schema": {
              "type": "integer",
              "default": 0,
              "title": "Wrong Count"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Successful Response",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/KUStatus"
                }
              }
            }
          },
          "422": {
            "description": "Validation Error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HTTPValidationError"
                }
              }
            }
          }
        }
      }
    },
    "/api/v1/learning/notes": {
      "post": {
        "tags": [
          "learning"
        ],
        "summary": "Add Note",
        "operationId": "add_note_api_v1_learning_notes_post",
        "security": [
          {
            "HTTPBearer": []
          }
        ],
        "parameters": [
          {
            "name": "ku_id",
            "in": "query",
            "required": true,
            "schema": {
              "type": "string",
              "title": "Ku Id"
            }
          },
          {
            "name": "note_content",
            "in": "query",
            "required": true,
            "schema": {
              "type": "string",
              "title": "Note Content"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Successful Response",
            "content": {
              "application/json": {
                "schema": {}
              }
            }
          },
          "422": {
            "description": "Validation Error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HTTPValidationError"
                }
              }
            }
          }
        }
      }
    },
    "/api/v1/learning/recent-reviews": {
      "get": {
        "tags": [
          "learning"
        ],
        "summary": "Get Recent Reviews",
        "operationId": "get_recent_reviews_api_v1_learning_recent_reviews_get",
        "security": [
          {
            "HTTPBearer": []
          }
        ],
        "parameters": [
          {
            "name": "limit",
            "in": "query",
            "required": false,
            "schema": {
              "type": "integer",
              "default": 5,
              "title": "Limit"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Successful Response",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "type": "object",
                    "additionalProperties": true
                  },
                  "title": "Response Get Recent Reviews Api V1 Learning Recent Reviews Get"
                }
              }
            }
          },
          "422": {
            "description": "Validation Error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HTTPValidationError"
                }
              }
            }
          }
        }
      }
    },
    "/health": {
      "get": {
        "summary": "Health Check",
        "operationId": "health_check_health_get",
        "responses": {
          "200": {
            "description": "Successful Response",
            "content": {
              "application/json": {
                "schema": {}
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "AnswerResult": {
        "properties": {
          "is_correct": {
            "type": "boolean",
            "title": "Is Correct"
          },
          "correct_answer": {
            "type": "string",
            "title": "Correct Answer"
          },
          "explanation": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Explanation"
          },
          "session_completed": {
            "type": "boolean",
            "title": "Session Completed",
            "default": false
          }
        },
        "type": "object",
        "required": [
          "is_correct",
          "correct_answer"
        ],
        "title": "AnswerResult"
      },
      "AnswerSubmission": {
        "properties": {
          "exercise_id": {
            "type": "string",
            "format": "uuid",
            "title": "Exercise Id"
          },
          "question_index": {
            "type": "integer",
            "title": "Question Index"
          },
          "user_answer": {
            "type": "string",
            "title": "User Answer"
          },
          "time_spent_seconds": {
            "type": "integer",
            "title": "Time Spent Seconds",
            "default": 0
          }
        },
        "type": "object",
        "required": [
          "exercise_id",
          "question_index",
          "user_answer"
        ],
        "title": "AnswerSubmission"
      },
      "HTTPValidationError": {
        "properties": {
          "detail": {
            "items": {
              "$ref": "#/components/schemas/ValidationError"
            },
            "type": "array",
            "title": "Detail"
          }
        },
        "type": "object",
        "title": "HTTPValidationError"
      },
      "KUStatus": {
        "properties": {
          "user_id": {
            "type": "string",
            "title": "User Id"
          },
          "item_id": {
            "type": "string",
            "title": "Item Id"
          },
          "item_type": {
            "type": "string",
            "title": "Item Type",
            "default": "ku"
          },
          "facet": {
            "type": "string",
            "title": "Facet"
          },
          "state": {
            "$ref": "#/components/schemas/SRSStage"
          },
          "stability": {
            "type": "number",
            "title": "Stability"
          },
          "difficulty": {
            "type": "number",
            "title": "Difficulty"
          },
          "reps": {
            "type": "integer",
            "title": "Reps"
          },
          "lapses": {
            "type": "integer",
            "title": "Lapses"
          },
          "last_review": {
            "anyOf": [
              {
                "type": "string",
                "format": "date-time"
              },
              {
                "type": "null"
              }
            ],
            "title": "Last Review"
          },
          "next_review": {
            "anyOf": [
              {
                "type": "string",
                "format": "date-time"
              },
              {
                "type": "null"
              }
            ],
            "title": "Next Review"
          },
          "character": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Character"
          },
          "meaning": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Meaning"
          },
          "notes": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Notes"
          }
        },
        "type": "object",
        "required": [
          "user_id",
          "item_id",
          "facet",
          "state",
          "stability",
          "difficulty",
          "reps",
          "lapses"
        ],
        "title": "KUStatus"
      },
      "KnowledgeUnit": {
        "properties": {
          "id": {
            "type": "string",
            "title": "Id"
          },
          "type": {
            "type": "string",
            "title": "Type"
          },
          "level": {
            "type": "integer",
            "title": "Level"
          },
          "character": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Character"
          },
          "meaning": {
            "type": "string",
            "title": "Meaning"
          },
          "slug": {
            "type": "string",
            "title": "Slug"
          },
          "metadata": {
            "additionalProperties": true,
            "type": "object",
            "title": "Metadata",
            "default": {}
          }
        },
        "type": "object",
        "required": [
          "id",
          "type",
          "level",
          "meaning",
          "slug"
        ],
        "title": "KnowledgeUnit"
      },
      "Rating": {
        "type": "string",
        "enum": [
          "again",
          "pass"
        ],
        "title": "Rating"
      },
      "SRSStage": {
        "type": "string",
        "enum": [
          "new",
          "learning",
          "review",
          "burned"
        ],
        "title": "SRSStage"
      },
      "ValidationError": {
        "properties": {
          "loc": {
            "items": {
              "anyOf": [
                {
                  "type": "string"
                },
                {
                  "type": "integer"
                }
              ]
            },
            "type": "array",
            "title": "Location"
          },
          "msg": {
            "type": "string",
            "title": "Message"
          },
          "type": {
            "type": "string",
            "title": "Error Type"
          },
          "input": {
            "title": "Input"
          },
          "ctx": {
            "type": "object",
            "title": "Context"
          }
        },
        "type": "object",
        "required": [
          "loc",
          "msg",
          "type"
        ],
        "title": "ValidationError"
      }
    },
    "securitySchemes": {
      "HTTPBearer": {
        "type": "http",
        "scheme": "bearer"
      }
    }
  }
}