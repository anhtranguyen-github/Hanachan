.next/
.next_clean/
dist/
build/
out/
__pycache__/
*.py[cod]
*$py.class
*.so
*.tsbuildinfo
next-env.d.ts

# --- Environment & Secrets ---
.env
.env.*
!.env.example
.secrets.baseline
*.pem
*.key
.env.keys

