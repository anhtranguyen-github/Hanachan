.agent/
.agents/
.kilocode/
.kiro/
.gemini/
.ruff_cache/
.pytest_cache/
.mypy_cache/
.vercel/

# --- Database & Storage ---
*.db
*.sqlite
*.sqlite3
data/
processed_data/
.supabase/
database_setup/
database_setup.sql

# --- Operating System ---
.DS_Store
.DS_Store?
._*
Thumbs.db
desktop.ini

