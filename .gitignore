# ==========================================
# Hanachan Monorepo - Comprehensive .gitignore
# ==========================================
# This file ensures deterministic builds by excluding:
# - Generated artifacts
# - Build outputs
# - Caches
# - Environment-specific files
# - Logs and temporary files
#
# SOURCE OF TRUTH files that MUST be tracked:
# - openapi/schema.json (API contract)
# - heyapi.config.ts (SDK generation config)
# - package.json (dependencies)
# - pnpm-lock.yaml (lockfile for reproducibility)
# - pyproject.toml (Python dependencies)
# - uv.lock (Python lockfile)
# ==========================================

# ==========================================
# 1. Dependencies & Package Managers
# ==========================================

# Node.js
node_modules/
.pnp
.pnp.js

# pnpm
.pnpm-store/

# Python environments
.venv/
venv/
ENV/
env/
*.egg-info/

# ==========================================
