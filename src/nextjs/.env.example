# Supabase Configuration (Local - Active)
NEXT_PUBLIC_SUPABASE_URL=http://127.0.0.1:54421
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_key_here
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here
DATABASE_URL=postgresql://postgres:postgres@127.0.0.1:54422/postgres

# Local Development Tools
SUPABASE_STUDIO_URL=http://127.0.0.1:54423
SUPABASE_INBUCKET_URL=http://127.0.0.1:54424
SUPABASE_STORAGE_S3_URL=http://127.0.0.1:54421/storage/v1/s3

# Storage Credentials
SUPABASE_STORAGE_ACCESS_KEY=your_access_key
SUPABASE_STORAGE_SECRET_KEY=your_secret_key
SUPABASE_STORAGE_REGION=local

# App Configuration
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_MOCK_MODE=false
# LLM Configuration (Omniroute - OpenAI-compatible local proxy)
OPENAI_API_KEY=sk-none
OPENAI_API_BASE_URL=http://localhost:20128/v1
LLM_MODEL=cost-saver
# LLM_PROVIDER=omniroute  # Set to 'omniroute' to use OMNIROUTE_* vars instead
# OMNIROUTE_BASE_URL=http://localhost:20128/v1
# OMNIROUTE_API_KEY=sk-none

AGENTS_API_URL=http://127.0.0.1:6100

# Azure AI Speech Configuration
AZURE_SPEECH_KEY=your_azure_speech_key_here
AZURE_SPEECH_REGION=eastus
