# Supabase Configuration (Cloud)
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_publishable_key_here
SUPABASE_SERVICE_ROLE_KEY=your_cloud_service_role_key_here
DATABASE_URL=your_cloud_database_url_here

# App Configuration
HANACHAN_FRONTEND_PORT=43100
HANACHAN_BACKEND_PORT=43110
HANACHAN_OMNIROUTE_PORT=43120
NEXT_PUBLIC_APP_URL=http://localhost:43100
NEXT_PUBLIC_MOCK_MODE=false
# LLM Configuration (Omniroute - OpenAI-compatible local proxy)
OPENAI_API_KEY=sk-none
OPENAI_API_BASE_URL=http://localhost:43120/v1
LLM_MODEL=cost-saver
# LLM_PROVIDER=omniroute  # Set to 'omniroute' to use OMNIROUTE_* vars instead
# OMNIROUTE_BASE_URL=http://localhost:43120/v1
# OMNIROUTE_API_KEY=sk-none

AGENTS_API_URL=http://127.0.0.1:43110

# Azure AI Speech Configuration
AZURE_SPEECH_KEY=your_azure_speech_key_here
AZURE_SPEECH_REGION=eastus
