# Copy this file to `.env` and fill in secrets. Do NOT commit your real `.env`.

# === AI & LLM CONFIGURATION ===
OPENAI_API_KEY=your-openai-key-here
LLM_PROVIDER=openai
LLM_MODEL=gpt-4o
EMBEDDING_PROVIDER=openai
EMBEDDING_MODEL=text-embedding-3-small

# === SUPABASE CLOUD (AUTH & API) ===
# Used by Next.js and FastAPI
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=your-service-key

# === POSTGRESQL DATABASE (DIRECT CONNECTION) ===
DB_HOST=your-db-host
DB_PORT=6543
DB_NAME=postgres
DB_USER=postgres.yourproject
DB_PASSWORD=yourpassword
DATABASE_URL=postgresql://postgres:password@your-db-host:6543/postgres?sslmode=require

# === VECTOR DATABASE (QDRANT CLOUD) ===
QDRANT_URL=https://your-qdrant-host:6333
QDRANT_API_KEY=your-qdrant-api-key

# === KNOWLEDGE GRAPH (NEO4J AURADB) ===
NEO4J_URI=neo4j+s://your.neo4j.io
NEO4J_USER=your-neo4j-user
NEO4J_PASSWORD=your-neo4j-password

# === APP SETTINGS ===
NEXT_PUBLIC_APP_URL=http://localhost:3000
MEMORY_API_URL=http://localhost:8765/api/v1
# Shared environment variables or docker compose settings
# e.g.:
COMPOSE_PROJECT_NAME=hanachan
NODE_ENV=development
