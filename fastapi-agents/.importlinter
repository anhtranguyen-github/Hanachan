[importlinter]
root_package = app
include_external_packages = True

[importlinter:contract:layers]
name = Layered architecture
type = layers
layers =
    app.api
    app.agents

[importlinter:contract:agents-no-db]
name = Agents must not access database modules directly
type = forbidden
source_modules =
    app.agents
forbidden_modules =
    app.core.supabase
    supabase

[importlinter:contract:api-no-vector]
name = API must not access vector database clients directly
type = forbidden
source_modules =
    app.api
forbidden_modules =
    app.core.qdrant
    qdrant_client
ignore_imports =
    app.services.memory.* -> qdrant_client
