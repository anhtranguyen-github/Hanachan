  "components": {
    "schemas": {
      "AddEpisodicRequest": {
        "properties": {
          "user_id": {
            "type": "string",
            "title": "User Id"
          },
          "text": {
            "type": "string",
            "title": "Text"
          }
        },
        "type": "object",
        "required": [
          "user_id",
          "text"
        ],
        "title": "AddEpisodicRequest"
      },
      "AddEpisodicResponse": {
        "properties": {
          "user_id": {
            "type": "string",
            "title": "User Id"
          },
          "text": {
            "type": "string",
            "title": "Text"
          },
          "id": {
            "type": "string",
            "title": "Id"
          }
        },
        "type": "object",
        "required": [
          "user_id",
          "text",
          "id"
        ],
        "title": "AddEpisodicResponse"
      },
      "AddSemanticRequest": {
        "properties": {
          "user_id": {
            "type": "string",
            "title": "User Id"
          },
          "nodes": {
            "items": {
              "$ref": "#/components/schemas/Node"
            },
            "type": "array",
            "title": "Nodes"
          },
          "relationships": {
            "items": {
              "$ref": "#/components/schemas/Relationship"
            },
            "type": "array",
            "title": "Relationships"
          }
        },
        "type": "object",
        "required": [
          "user_id",
          "nodes",
          "relationships"
        ],
        "title": "AddSemanticRequest"
      },
      "AddSemanticResponse": {
        "properties": {
          "user_id": {
            "type": "string",
            "title": "User Id"
          },
          "nodes_added": {
            "type": "integer",
            "title": "Nodes Added"
          },
          "relationships_added": {
            "type": "integer",
            "title": "Relationships Added"
          }
        },
        "type": "object",
        "required": [
          "user_id",
          "nodes_added",
          "relationships_added"
        ],
        "title": "AddSemanticResponse"
      },
      "ChatRequest": {
        "properties": {
          "user_id": {
            "type": "string",
            "title": "User Id",
            "description": "User UUID \u2014 must match the authenticated token subject."
          },
          "message": {
            "type": "string",
            "maxLength": 4000,
            "minLength": 1,
            "title": "Message",
            "description": "Max 4000 characters (~1000 tokens)."
          },
          "session_id": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Session Id",
            "description": "Session ID for thread continuity. If omitted, no session context is used."
          },
          "tts_enabled": {
            "type": "boolean",
            "title": "Tts Enabled",
            "description": "If True, the agent will generate audio for the response.",
            "default": false
          }
        },
        "type": "object",
        "required": [
          "user_id",
          "message"
        ],
        "title": "ChatRequest"
      },
      "ChatResponse": {
        "properties": {
          "user_id": {
            "type": "string",
            "title": "User Id"
          },
          "session_id": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Session Id"
          },
          "message": {
            "type": "string",
            "title": "Message"
          },
          "response": {
            "type": "string",
            "title": "Response"
          },
          "episodic_context": {
            "type": "string",
            "title": "Episodic Context",
            "default": ""
          },
          "semantic_context": {
            "type": "string",
            "title": "Semantic Context",
            "default": ""
          },
          "thread_context": {
            "type": "string",
            "title": "Thread Context",
            "default": ""
          }
        },
        "type": "object",
        "required": [
          "user_id",
          "message",
          "response"
        ],
        "title": "ChatResponse"
      },
      "ClearResponse": {
        "properties": {
          "user_id": {
            "type": "string",
            "title": "User Id"
          },
          "message": {
            "type": "string",
            "title": "Message"
          }
        },
        "type": "object",
        "required": [
          "user_id",
          "message"
        ],
        "title": "ClearResponse"
      },
      "ConsolidationResult": {
        "properties": {
          "user_id": {
            "type": "string",
            "title": "User Id"
          },
          "memories_before": {
            "type": "integer",
            "title": "Memories Before"
          },
          "memories_after": {
            "type": "integer",
            "title": "Memories After"
          },
          "batches_merged": {
            "type": "integer",
            "title": "Batches Merged"
          },
          "message": {
            "type": "string",
            "title": "Message"
          }
        },
        "type": "object",
        "required": [
          "user_id",
          "memories_before",
          "memories_after",
          "batches_merged",
          "message"
        ],
        "title": "ConsolidationResult"
      },
      "ContextRequest": {
        "properties": {
          "user_id": {
            "type": "string",
            "title": "User Id"
          },
          "query": {
            "type": "string",
            "title": "Query"
          },
          "session_id": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Session Id"
          },
          "max_episodic": {
            "type": "integer",
            "maximum": 10.0,
            "minimum": 1.0,
            "title": "Max Episodic",
