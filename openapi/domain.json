  "components": {
    "schemas": {
      "AnswerResult": {
        "properties": {
          "is_correct": {
            "type": "boolean",
            "title": "Is Correct"
          },
          "correct_answer": {
            "type": "string",
            "title": "Correct Answer"
          },
          "explanation": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Explanation"
          },
          "session_completed": {
            "type": "boolean",
            "title": "Session Completed",
            "default": false
          }
        },
        "type": "object",
        "required": [
          "is_correct",
          "correct_answer"
        ],
        "title": "AnswerResult"
      },
      "AnswerSubmission": {
        "properties": {
          "exercise_id": {
            "type": "string",
            "format": "uuid",
            "title": "Exercise Id"
          },
          "question_index": {
            "type": "integer",
            "title": "Question Index"
          },
          "user_answer": {
            "type": "string",
            "title": "User Answer"
          },
          "time_spent_seconds": {
            "type": "integer",
            "title": "Time Spent Seconds",
            "default": 0
          }
        },
        "type": "object",
        "required": [
          "exercise_id",
          "question_index",
          "user_answer"
        ],
        "title": "AnswerSubmission"
      },
      "ChatMessagePayload": {
        "properties": {
          "role": {
            "type": "string",
            "title": "Role"
          },
          "content": {
            "type": "string",
            "title": "Content"
          }
        },
        "type": "object",
        "required": [
          "role",
          "content"
        ],
        "title": "ChatMessagePayload"
      },
      "ChatSessionUpdatePayload": {
        "properties": {
          "title": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Title"
          },
          "summary": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Summary"
          }
        },
        "type": "object",
        "title": "ChatSessionUpdatePayload"
      },
      "DeckCreate": {
        "properties": {
          "name": {
            "type": "string",
